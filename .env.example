# ─── Home-Ops Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control — it contains secrets.
#
# Configuration reference:
#   user_profile.yml  → scraping URLs, scoring thresholds, alert schedule
#   HOME_OPS_CONFIG   → override user_profile.yml path (default: ./user_profile.yml)


# ─── Required ─────────────────────────────────────────────────────────────────

# Telegram bot token for alert notifications.
# Create one via @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID where alerts will be sent.
# Get it by messaging @userinfobot on Telegram after starting your bot.
# Also accepted as CHAT_ID for backward compatibility.
TELEGRAM_CHAT_ID=

# Gemini API key for LLM-powered description analysis (optional enhancement).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=


# ─── Optional ─────────────────────────────────────────────────────────────────

# Apify API token (only if you want to use Apify-based scraping instead of
# the built-in Scrapling fetcher).
# https://console.apify.com/
APIFY_API_TOKEN=
